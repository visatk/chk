{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "auth",
	"main": "src/index.ts",
	"compatibility_date": "2026-04-29",
	"compatibility_flags": [
		"nodejs_compat"
	],
	"observability": {
		"enabled": true
	},
    "d1_databases": [
    {
      "binding": "DB",
      "database_name": "personal-bot",
      "database_id": "3f72b578-a57d-4262-88f1-58e5bc1b4ba4"
    }
  ],
   "kv_namespaces": [
    {
      "binding": "KV",
      "id": "xxxxxxxxxxxxxxx"
    }
  ]
}
